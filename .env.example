# BotVault Configuration

# Flutterwave Payment API Settings
FLW_SECRET_KEY="FLW_SECRET_KEY_HERE"
FLW_SECRET_HASH="FLW_SECRET_HASH_HERE"
FLW_REDIRECT_URL="MY_APP_URL/payment-success"

# Google Gemini API Key
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Config (Admin SDK automatically reads these)
FIREBASE_PROJECT_ID="aerobic-limiter-jtsmh"

# Port (Using 3000 for standard container ingress, fallback to 3001)
PORT=3000

# Admin Contact Phone (for bot support and administration)
ADMIN_PHONE="2348000000000"

# Application Public URL (Auto-injected in production)
APP_URL="MY_APP_URL"
